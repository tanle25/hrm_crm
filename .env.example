# App
APP_NAME=Content Forge v2
APP_ENV=development
API_PREFIX=/api
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
AUTH_SECRET=change-this-local-secret
AUTH_COOKIE_NAME=content_forge_session
QUEUE_MODE=inline
DEFAULT_PUBLISH_STATUS=draft
MAX_QUEUE_SIZE=100
MAX_RETRIES=2
PROCESSING_TIMEOUT_SEC=600

# LLM
LLM_PRIMARY_PROVIDER=router
LLM_DISABLE_FALLBACKS=true
LLM_TIMEOUT_SEC=60
LLM_TIMEOUT_EXTRACT_PLANNER_SEC=120
LLM_TIMEOUT_WRITER_SEC=360
LLM_TIMEOUT_HUMANIZER_SEC=240
LLM_TIMEOUT_QA_SEC=180
LLM_ROUTER_RETRY_ATTEMPTS=2
LLM_ROUTER_RETRY_BACKOFF_MS=2000
LLM_MODEL_EXTRACT_PLANNER=gpt-5.4-mini
LLM_MODEL_WRITER=gpt-5.4
LLM_MODEL_HUMANIZER=gpt-5.4
LLM_MODEL_QA=gpt-5.4-mini
LLM_MODEL_FALLBACK=gpt-5.4

# Optional Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_HAIKU=claude-3-5-haiku-latest
ANTHROPIC_MODEL_SONNET=claude-3-7-sonnet-latest

# Router / Groq / Ollama
ROUTER_BASE=http://localhost:8317/v1
ROUTER_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SEC=60
OLLAMA_BASE=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_TIMEOUT_SEC=180

# WooCommerce
WOO_DEFAULT_STATUS=draft
WOO_DEFAULT_PRICE=99000

# Redis / Chroma
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://content_forge:content_forge@localhost:55432/content_forge
CHROMA_PATH=./data/chroma

# Media / Search
UNSPLASH_ACCESS_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Observability / Optional
WEBHOOK_URL=
AUTHOR_NAME=Content Forge
METRICS_ENABLED=true
METRICS_PORT=8001
