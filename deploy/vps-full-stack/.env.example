POSTGRES_PASSWORD=change-me

# App auth
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SECRET=change-this-session-secret
AUTH_COOKIE_NAME=content_forge_session

# LLM routing through cliproxy in the same Docker network
ROUTER_KEY=replace-with-your-cliproxy-api-key
LLM_PRIMARY_PROVIDER=router
LLM_DISABLE_FALLBACKS=true
LLM_MODEL_EXTRACT_PLANNER=gpt-5.4-mini
LLM_MODEL_WRITER=gpt-5.4
LLM_MODEL_HUMANIZER=gpt-5.4
LLM_MODEL_QA=gpt-5.4-mini
LLM_TIMEOUT_SEC=60
LLM_TIMEOUT_EXTRACT_PLANNER_SEC=120
LLM_TIMEOUT_WRITER_SEC=360
LLM_TIMEOUT_HUMANIZER_SEC=240
LLM_TIMEOUT_QA_SEC=180
LLM_ROUTER_RETRY_ATTEMPTS=2
LLM_ROUTER_RETRY_BACKOFF_MS=2000

# Publishing defaults
DEFAULT_PUBLISH_STATUS=draft
WOO_DEFAULT_STATUS=draft
WOO_DEFAULT_PRICE=99000

# App behavior
APP_ENV=production
API_PREFIX=/api
QUEUE_MODE=rq
MAX_QUEUE_SIZE=100
MAX_RETRIES=2
PROCESSING_TIMEOUT_SEC=600
METRICS_ENABLED=true
METRICS_PORT=8001
AUTHOR_NAME=Content Forge

# Optional
WEBHOOK_URL=
UNSPLASH_ACCESS_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
